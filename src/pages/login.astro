---
import Navbar from '../components/Navbar.astro'
import Layout from '../layouts/Layout.astro'
---

<Layout title='login | d4er portfolio'>
    <Navbar
        home='/'
        projects='/#projects'
        about='/#about'
        contact='/#contact'
        display='hidden'
    />
    <div
        class='h-full bg-gradient-to-br from-[#181b20] to-[#312e33] relative overflow-y-hidden'
    >
        <form
            action='submit'
            id='form-login'
            class='text-white relative left-[50%] border-[4px] translate-x-[-50%] border-white rounded-lg top-[53%] translate-y-[-50%] bg-[#201f1f] shadow-custom max-[500px]:w-full max-[500px]:border-none max-[500px]:shadow-none max-[500px]:rounded-none max-[500px]:h-[100vh] max-[500px]:top-[50vh]'
        >
            <div class='flex justify-center'>
                <span class='text-center relative top-20 bold-txt'
                    >inicia sesión</span
                >
            </div>
            <input
                type='email'
                class='left-[50%] translate-x-[-50%] relative top-[30%] w-[70%] text-black bg-slate-50 outline-none rounded-lg'
                placeholder='email'
                id='email'
                style='padding-left: 10px;'
                autocomplete='off'
            />
            <div
                id='email-error'
                class='text-red-500 left-[50%] translate-x-[-50%] relative top-[31%] w-[70%]'
            >
            </div>
            <input
                type='password'
                class='left-[50%] translate-x-[-50%] relative top-[35%] w-[70%] text-black bg-slate-50 outline-none rounded-lg'
                placeholder='contraseña'
                id='password'
                style='padding-left: 10px;'
                autocomplete='off'
            />
            <div
                id='password-error'
                class='text-red-500 left-[50%] translate-x-[-50%] relative top-[36%] w-[70%]'
            >
            </div>
            <a
                href='/singup'
                class='relative translate-y-[-50%] inline-block hover:underline singup max-[721px]:ml-[7rem] max-[475px]:ml-[5rem] max-[352px]:ml-[3rem]'
                title='singup'
            >
                o crear cuenta
            </a>
            <button
                type='submit'
                class='float-right relative translate-y-[-50%] hover:underline next max-[721px]:mr-[7rem] max-[475px]:mr-[5rem] max-[352px]:mr-[3rem]'
                >siguiente</button
            >
        </form>
        <style>
            .shadow-custom {
                box-shadow: 0 0 20px;
                width: 500px;
                height: 80vh;
            }
            .singup {
                margin-left: 5rem;
                top: 40.2%;
            }
            .next {
                margin-right: 5rem;
                top: 40%;
            }
            @media screen and (max-height: 712px) {
                .shadow-custom {
                    box-shadow: none;
                    border: none;
                    width: 100% !important;
                    height: 100vh !important;
                }
                .singup {
                    margin-left: 12rem;
                    top: 44.2%;
                }
                .next {
                    margin-right: 12rem;
                    top: 44%;
                }
            }
            .bold-txt {
                font-weight: bold;
                font-size: 30px;
            }
        </style>
    </div>
</Layout>

<script>
    const $form = document.querySelector('#form-login')
    $form?.addEventListener('submit', (event) => {
        event.preventDefault()

        const em = document.querySelector('#email') as HTMLInputElement
        const password = document.querySelector('#password') as HTMLInputElement

        const email = em.value
        const pass = password.value

        fetch('https://d4erapi56.onrender.com/api/login', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                email: email,
                password: pass,
            }),
            credentials: 'include',
        })
            .then((response) => {
                if (response.ok) {
                    response.json().then((data) => {
                        document.cookie = 'token=' + data.token
                        window.location.href = '/'
                    })
                } else if (response.status == 400) {
                    response.text().then((data) => {
                        if (data.includes('User not found')) {
                            const errorDiv = document.querySelector(
                                '#email-error'
                            ) as HTMLDivElement
                            errorDiv.textContent =
                                'usuario no encontrado asegurate de escribir lo bien'
                            errorDiv.style.display = 'block'
                            const email = document.querySelector(
                                '#email'
                            ) as HTMLInputElement
                            email.addEventListener('input', () => {
                                errorDiv.style.display = 'none'
                            })
                        } else if (data.includes('Invalid credential')) {
                            const errorDiv = document.querySelector(
                                '#password-error'
                            ) as HTMLDivElement
                            errorDiv.textContent = 'contraseña incorrecta'
                            errorDiv.style.display = 'block'
                        }
                    })
                }
            })
            .catch((error) => {
                console.error(error)
            })
    })
</script>
<script>
    const password = document.querySelector('#password') as HTMLInputElement
    const errorDiv = document.querySelector('#password-error') as HTMLDivElement

    password.addEventListener('input', (e) => {
        if (password.value.length < 6) {
            errorDiv.textContent =
                'La contraseña debe tener al menos seis caracteres'
            errorDiv.style.display = 'block'
        } else {
            errorDiv.textContent = ''
            errorDiv.style.display = 'none'
        }
    })
    password.addEventListener('blur', (e) => {
        if (password.value === '') {
            errorDiv.style.display = 'none'
        }
    })
</script>
